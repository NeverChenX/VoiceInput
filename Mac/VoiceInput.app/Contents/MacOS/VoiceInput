#!/bin/bash
# Launcher — compiles (if needed) and runs the app.
RESOURCES="$(cd "$(dirname "$0")/../Resources" && pwd)"
SOURCE="$RESOURCES/main.swift"

CACHE_DIR="$HOME/.cache/VoiceInput"
mkdir -p "$CACHE_DIR"
BINARY="$CACHE_DIR/VoiceInput_bin"
ERRLOG="/tmp/voiceinput_compile_error.log"

if ! xcrun --find swiftc &>/dev/null; then
    osascript -e 'display alert "VoiceInput" message "未找到 Swift 编译器。请安装 Xcode 命令行工具：\n\nxcode-select --install" as critical'
    exit 1
fi

# Get the correct SDK path to avoid SwiftBridging module conflict
SDKPATH=$(xcrun --sdk macosx --show-sdk-path 2>/dev/null)

# Recompile if binary missing or source newer
if [ ! -f "$BINARY" ] || [ "$SOURCE" -nt "$BINARY" ]; then
    rm -f "$BINARY" 2>/dev/null
    xcrun --sdk macosx swiftc -O -swift-version 5 \
        -sdk "$SDKPATH" \
        -framework AppKit -framework AVFoundation -framework CoreGraphics \
        -o "$BINARY" "$SOURCE" >"$ERRLOG" 2>&1
    if [ $? -ne 0 ]; then
        ERRMSG=$(head -15 "$ERRLOG" 2>/dev/null | sed 's/"/\\"/g')
        osascript -e "display alert \"VoiceInput 编译失败\" message \"$ERRMSG\" as critical"
        exit 1
    fi
    rm -f "$ERRLOG" 2>/dev/null
fi

cd "$RESOURCES"
exec "$BINARY"
